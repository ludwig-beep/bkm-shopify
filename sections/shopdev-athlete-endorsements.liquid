{{ 'shopdev-athlete-endorsements.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web/src/regular/style.css" />

<style>
  .shopdev-athlete-endorsements .athlete-endorsements .swiper-pagination-bullet {
    width: 8px;
    height: 8px;
    background: #000000;
    opacity: 0.3;
  }
  
  .shopdev-athlete-endorsements .athlete-endorsements .swiper-pagination-bullet-active {
    opacity: 1;
  }
  
  .shopdev-athlete-endorsements .athlete-endorsements .swiper-button-next,
  .shopdev-athlete-endorsements .athlete-endorsements .swiper-button-prev {
    color: #000000;
  }
  
  .shopdev-athlete-endorsements .athlete-endorsements .swiper-button-next:after,
  .shopdev-athlete-endorsements .athlete-endorsements .swiper-button-prev:after {
    font-size: 24px;
  }
  
  .shopdev-athlete-endorsements .athlete-endorsements .athlete-quote {
    position: relative;
  }
  
  .shopdev-athlete-endorsements .athlete-endorsements .athlete-quote:before {
    content: """;
    position: absolute;
    top: -20px;
    left: -10px;
    font-size: 60px;
    color: rgba(0, 0, 0, 0.1);
    font-family: serif;
  }
  
  @media (max-width: 768px) {
    .shopdev-athlete-endorsements .athlete-endorsements .swiper-button-next,
    .shopdev-athlete-endorsements .athlete-endorsements .swiper-button-prev {
      display: none;
    }
  }
</style>

<div class="athlete-endorsements py-12 md:py-16">
  <div class="container mx-auto px-4">
    {% if section.settings.heading != blank %}
      <h2 class="text-center text-3xl md:text-4xl font-bold mb-8 md:mb-12">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <p class="text-center text-base md:text-lg mb-8 md:mb-12 max-w-3xl mx-auto">{{ section.settings.subheading }}</p>
    {% endif %}
    
    {% if section.blocks.size > 0 %}
      <div class="swiper athlete-swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'athlete' %}
              <div class="swiper-slide" {{ block.shopify_attributes }}>
                <div class="flex flex-col md:flex-row items-center bg-white rounded-lg overflow-hidden shadow-md">
                  <div class="w-full md:w-2/5 h-[300px] md:h-[400px]">
                    {% if block.settings.image != blank %}
                      {{ block.settings.image | image_url: width: 800 | image_tag: 
                        class: 'w-full h-full object-cover',
                        loading: 'lazy',
                        alt: block.settings.name
                      }}
                    {% else %}
                      <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                        <i class="ph ph-user text-gray-400" style="font-size: 64px;"></i>
                      </div>
                    {% endif %}
                  </div>
                  
                  <div class="w-full md:w-3/5 p-6 md:p-8 flex flex-col justify-center">
                    {% if block.settings.quote != blank %}
                      <div class="athlete-quote text-lg md:text-xl italic mb-6 relative">
                        "{{ block.settings.quote }}"
                      </div>
                    {% endif %}
                    
                    <div class="flex items-center">
                      {% if block.settings.name != blank %}
                        <div>
                          <h3 class="font-bold text-xl">{{ block.settings.name }}</h3>
                          {% if block.settings.title != blank %}
                            <p class="text-gray-600">{{ block.settings.title }}</p>
                          {% endif %}
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        
        {% if section.settings.show_navigation %}
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
        {% endif %}
        
        {% if section.settings.show_pagination %}
          <div class="swiper-pagination mt-6"></div>
        {% endif %}
      </div>
    {% else %}
      <div class="text-center py-10 bg-gray-100 rounded-lg">
        <p>Add athlete endorsements to showcase your partnerships</p>
      </div>
    {% endif %}
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const athleteSwiper = new Swiper('.athlete-swiper', {
      slidesPerView: 1,
      spaceBetween: 30,
      loop: {{ section.settings.enable_loop | json }},
      autoplay: {% if section.settings.enable_autoplay %}
        {
          delay: {{ section.settings.autoplay_delay }},
          disableOnInteraction: false,
        }
      {% else %}
        false
      {% endif %},
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      breakpoints: {
        768: {
          slidesPerView: {{ section.settings.slides_per_view }},
          spaceBetween: 30
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Athlete Endorsements",
  "class": "shopdev shopdev-athlete-endorsements",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Professional Athletes"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "See what top performers say about our products"
    },
    {
      "type": "range",
      "id": "slides_per_view",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Athletes per row (desktop)",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 3000,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "label": "Autoplay delay",
      "default": 5000
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable infinite loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination dots",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "athlete",
      "name": "Athlete",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Athlete image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Athlete name",
          "default": "Alex Johnson"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Athlete title/role",
          "default": "Olympic Gold Medalist"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Athlete quote",
          "default": "This product has been a game-changer for my recovery routine. I've noticed significant improvements in my sleep quality and overall performance."
        }
      ]
    }
  ],
  "presets": [
    {
