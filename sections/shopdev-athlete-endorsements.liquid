        {
          "type": "athlete",
          "settings": {
            "image": "shopify://shop_images/ocean-water-with-swimmers.jpg",
            "name": "Michael Chen",
            "title": "World Champion Swimmer",
            "quote": "Ultra Focused gives me the mental clarity I need during competitions without the jitters of caffeine. It's become an essential part of my pre-race routine."
          }
