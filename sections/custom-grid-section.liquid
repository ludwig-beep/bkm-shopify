{% schema %}
{
  "name": "Custom Grid Section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1
    }
  ],
  "blocks": [
    {
      "type": "grid_item",
      "name": "Grid Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "item_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "item_heading",
          "label": "Heading",
          "default": "Your Heading"
        },
        {
          "type": "textarea",
          "id": "item_paragraph",
          "label": "Paragraph",
          "default": "Your paragraph text goes here."
        },
        {
          "type": "richtext",
          "id": "item_text",
          "label": "Textarea",
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Grid Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}
<div class="wrapper">
  <div class="custom-grid-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="grid">
    {% for block in section.blocks %}
      <div class="grid-item">
        {% if block.settings.item_image %}
          <img class="custom-grid-image" src="{{ block.settings.item_image | img_url: '1000x1000' }}" alt="{{ block.settings.item_heading }}">
        {% endif %}
        <h3>{{ block.settings.item_heading }}</h3>
        <p>{{ block.settings.item_paragraph }}</p>
        <p>{{ block.settings.item_text }}</p>
      </div>
    {% endfor %}
  </div>
  </div>
</div>

<style>
.custom-grid-section .grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}

.custom-grid-section .grid-item {
  text-align: left;
}

.custom-grid-section .grid-item img {
  max-width: 100%;
  height: auto;
}

.custom-grid-section .grid-item h3 {
  margin-top: 10px;
  font-size: 18px;
}

.custom-grid-section .grid-item p {
  font-size: 14px;
  margin-top: 5px;
}

.custom-grid-image {
  width: 100%;
  object-fit: cover;
  aspect-ratio: 1 / 1;
  border-radius: 20px;
}

@media (max-width: 1024px) {
  .custom-grid-section .grid {
    grid-template-columns: 1fr; /* Set to 1 column */
  }
}
</style>
