{{ 'shopdev-image-button-grid.css' | asset_url | stylesheet_tag }}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web/src/regular/style.css" />

<style>
  .shopdev-image-button-grid .image-button {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    cursor: pointer;
    display: block;
    text-decoration: none;
    flex-shrink: 0;
  }

  .shopdev-image-button-grid .button-overlay {
    position: absolute;
    inset: 0;
    transition: opacity 0.3s ease;
  }

  .shopdev-image-button-grid .button-text {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    padding: 16px;
    color: white;
    font-weight: 600;
    font-size: 18px;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
    z-index: 10;
  }

  .shopdev-image-button-grid .image-button:focus {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  .shopdev-image-button-grid .horizontal-scroll {
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .shopdev-image-button-grid .horizontal-scroll::-webkit-scrollbar {
    display: none;
  }

  @media (max-width: 768px) {
    .shopdev-image-button-grid .button-text {
      padding: 12px;
    }
  }
</style>

<div class="w-full py-12 md:py-16">
  {% if section.settings.section_width == 'full_width' %}
    <div class="w-full">
  {% elsif section.settings.section_width == 'full_width_padded' %}
    <div class="w-full px-4 sm:px-6 lg:px-8">
  {% else %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  {% endif %}
    
    <!-- Section Header -->
    {% if section.settings.heading != blank %}
      <div class="mb-12 {% if section.settings.text_alignment == 'left' %}text-left{% elsif section.settings.text_alignment == 'right' %}text-right{% else %}text-center{% endif %}">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: {{ section.settings.heading_color }}">
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}

    <!-- Horizontal Image Display -->
    {% if section.blocks.size > 0 %}
      <div class="horizontal-scroll">
        <div class="flex gap-2 md:gap-3 pb-4 justify-start md:justify-center">
          {% for block in section.blocks %}
            <a href="{{ block.settings.button_link | default: '#' }}" 
               class="image-button aspect-[5/1.82] w-48 md:w-64 group"
             {{ block.shopify_attributes }}
             {% if block.settings.button_link == blank %}onclick="return false;"{% endif %}
             role="button"
             tabindex="0"
             aria-label="{{ block.settings.button_text | default: block.settings.image_alt | default: 'Image button' }}">
            
            <!-- Background Image -->
            <div class="w-full h-full relative">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: 
                  class: 'w-full h-full object-cover',
                  loading: 'lazy',
                  alt: block.settings.image_alt | default: block.settings.button_text,
                  sizes: '(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw'
                }}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full bg-gray-200' }}
              {%- endif -%}

              <!-- Color Overlay -->
              {% if block.settings.enable_overlay %}
                <div class="button-overlay" 
                     style="background-color: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity }};">
                </div>
              {% endif %}

              <!-- Button Text -->
              {% if block.settings.button_text != blank %}
                <div class="button-text {% if section.settings.text_alignment == 'left' %}justify-start{% elsif section.settings.text_alignment == 'right' %}justify-end{% else %}justify-center{% endif %}">
                  <span>{{ block.settings.button_text }}</span>
                </div>
              {% endif %}

            </div>
            </a>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="text-center py-12">
        <p class="text-gray-500 text-lg">Add image buttons to get started</p>
      </div>
    {% endif %}
  </div>
</div>

<script>
  // Add keyboard navigation support
  document.addEventListener('DOMContentLoaded', function() {
    const imageButtons = document.querySelectorAll('.shopdev-image-button-grid .image-button');
    
    imageButtons.forEach(button => {
      button.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          this.click();
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Image Button Grid",
  "class": "shopdev shopdev-image-button-grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
