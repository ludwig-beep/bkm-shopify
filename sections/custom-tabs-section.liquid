{% schema %}
{
  "name": "Custom Tabs Section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "What our athletes say"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        {
          "value": "full_width",
          "label": "Full Width Padded"
        },
        {
          "value": "page_width",
          "label": "Page Width"
        },
        {
          "value": "boxed",
          "label": "Boxed Width"
        }
      ],
      "default": "page_width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "type": "checkbox",
      "id": "show_tab_buttons",
      "label": "Show tab buttons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title",
          "default": "Tab"
        },
        {
          "type": "image_picker",
          "id": "tab_image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "tab_name",
          "label": "Name",
          "default": "John Doe"
        },
        {
          "type": "textarea",
          "id": "tab_quote",
          "label": "Quote",
          "default": "This is a sample quote."
        },
        {
          "type": "text",
          "id": "tab_role",
          "label": "Role/Title",
          "default": "Swedish Olympic Judoka"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Tabs Section",
      "category": "Custom",
      "blocks": [
        {
          "type": "tab"
        }
      ]
    }
  ]
}
{% endschema %}

<div class="section-wrapper section-width-{{ section.settings.section_width }}">
  <div class="custom-tabs-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    {% if section.settings.section_title != blank %}
      <h2 class="section-title" style="text-align: {{ section.settings.title_alignment }};">
        {{ section.settings.section_title }}
      </h2>
    {% endif %}
    
    {% if section.settings.show_tab_buttons %}
      <ul class="tabs">
        {% for block in section.blocks %}
          <li class="tab-link {% if forloop.first %}active{% endif %}" data-tab="tab-{{ block.id }}">
            {{ block.settings.tab_title }}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
    
    <div class="tab-container">
      <button class="tab-arrow prev" aria-label="Previous tab">←</button>
      <div class="tab-navigation">
        <div class="tab-progress-bar"><div class="tab-progress"></div></div>
      </div>
      <button class="tab-arrow next" aria-label="Next tab">→</button>
    </div>
    
    <div class="tab-content">
      {% for block in section.blocks %}
        <div id="tab-{{ block.id }}" class="tab-item {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
          <div class="tab-item-content">
            <div class="image-container">
              <img 
                src="{{ block.settings.tab_image | image_url: width: 800 }}" 
                alt="{{ block.settings.tab_name }}"
                loading="lazy"
                width="800"
                height="800">
            </div>
            <div class="tab-text">
              <h3>{{ block.settings.tab_name }}</h3>
              <p class="quote">{{ block.settings.tab_quote }}</p>
              {% if block.settings.tab_role %}
                <p class="role">{{ block.settings.tab_role }}</p>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% style %}
*, *::before, *::after {
  box-sizing: border-box;
}

.section-wrapper {
  width: 100%;
  margin: 0 auto;
}

.section-width-full_width {
  width: 100%;
  padding-left: 30px;
  padding-right: 30px;
}

.section-width-page_width {
  max-width: 1400px;
  margin: 0 auto;
  padding-left: 30px;
  padding-right: 30px;
}

.section-width-boxed {
  max-width: 1200px;
  margin: 0 auto;
  padding-left: 30px;
  padding-right: 30px;
}

.section-title {
  margin: 0 0 40px 0;
  font-size: 2.5rem;
  font-weight: 600;
  color: #0A2240;
}

.custom-tabs-section {
  width: 100%;
}

.tabs {
  display: flex;
  list-style: none;
  justify-content: left;
  gap: 15px;
  padding: 0;
  margin: 0 0 2rem 0;
}

.tab-link {
  padding: 10px 20px;
  background-color: #f2f2f2;
  cursor: pointer;
  border-radius: 5px;
  transition: all 0.3s ease;
}

.tab-link.active {
  background-color: #0A2240;
  color: #fff;
}

.tab-content .tab-item {
  display: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.tab-content .tab-item.active {
  display: block;
  opacity: 1;
}

.tab-item-content {
  width: 100%;
  display: grid;
  grid-template-columns: 0.75fr 1fr;
  gap: 4rem;
  align-items: center;
}

.image-container {
  width: 100%;
  border-radius: 20px;
  overflow: hidden;
  aspect-ratio: 1;
}

.image-container img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.tab-text h3 {
  margin: 0 0 1rem 0;
  font-size: 2rem;
  color: #0A2240;
}

.tab-text .quote {
  font-style: italic;
  font-size: 1.2rem;
  line-height: 1.6;
  margin: 0 0 1rem 0;
}

.tab-text .role {
  color: #666;
  font-size: 1rem;
  margin: 0;
}

.tab-container {
  display: flex;
  align-items: center;
  gap: 15px;
  margin: 15px 0;
  width: 100%;
}

.tab-navigation {
  flex: 1;
}

.tab-progress-bar {
  width: 100%;
  height: 2px;
  background: rgba(0, 0, 0, 0.1);
}

.tab-progress {
  height: 100%;
  width: 0%;
  background: #000;
  transition: width 0.1s linear;
}

.tab-arrow {
  background: none;
  border: none;
  padding: 8px 12px;
  cursor: pointer;
  font-size: 18px;
  color: #000;
  transition: opacity 0.2s;
}

.tab-arrow:hover {
  opacity: 0.7;
}

@media screen and (max-width: 1024px) {
  .section-title {
    font-size: 2.2rem;
  }

  .tab-item-content {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .image-container {
    max-width: 600px;
    margin: 0 auto;
  }
}

@media screen and (max-width: 768px) {
  .section-title {
    font-size: 2rem;
    margin-bottom: 30px;
  }

  .section-width-full_width,
  .section-width-page_width,
  .section-width-boxed {
    padding-left: 20px;
    padding-right: 20px;
  }

  .tabs {
    flex-wrap: wrap;
  }
  
  .tab-link {
    flex: 1 1 100%;
    text-align: center;
  }

  .tab-text h3 {
    font-size: 1.8rem;
  }

  .tab-text .quote {
    font-size: 1.1rem;
  }
}
{% endstyle %}

<script>
document.addEventListener('DOMContentLoaded', function() {
  const tabsSection = document.querySelector('.custom-tabs-section');
  const tabs = tabsSection.querySelectorAll('.tab-link');
  const tabItems = tabsSection.querySelectorAll('.tab-item');
  const progressBar = tabsSection.querySelector('.tab-progress');
  const prevButton = tabsSection.querySelector('.tab-arrow.prev');
  const nextButton = tabsSection.querySelector('.tab-arrow.next');
  let currentIndex = 0;
  let startTime;
  let animationFrame;
  let autoRotateInterval;

  function switchTab(index) {
    currentIndex = index;
    
    // Remove active class from all tabs and items
    tabItems.forEach(item => item.classList.remove('active'));
    tabs.forEach(tab => tab.classList.remove('active'));
    
    // Add active class to current tab and item
    tabItems[currentIndex].classList.add('active');
    if (tabs.length > 0) {
      tabs[currentIndex].classList.add('active');
    }
    
    startProgress();
    resetAutoRotate();
  }

  function updateProgress(timestamp) {
    if (!startTime) startTime = timestamp;
    const elapsed = timestamp - startTime;
    const progress = Math.min((elapsed / 10000) * 100, 100);
    progressBar.style.width = `${progress}%`;
    
    if (progress < 100) {
      animationFrame = requestAnimationFrame(updateProgress);
    }
  }

  function startProgress() {
    if (animationFrame) {
      cancelAnimationFrame(animationFrame);
    }
    startTime = null;
    progressBar.style.width = '0%';
    animationFrame = requestAnimationFrame(updateProgress);
  }

  function resetAutoRotate() {
    clearInterval(autoRotateInterval);
    autoRotateInterval = setInterval(nextTab, 10000);
  }

  function nextTab() {
    switchTab((currentIndex + 1) % tabItems.length);
  }

  function prevTab() {
    switchTab((currentIndex - 1 + tabItems.length) % tabItems.length);
  }

  // Event Listeners
  nextButton.addEventListener('click', () => {
    nextTab();
    resetAutoRotate();
  });
  
  prevButton.addEventListener('click', () => {
    prevTab();
    resetAutoRotate();
  });
  
  if (tabs.length > 0) {
    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        switchTab(index);
        resetAutoRotate();
      });
    });
  }

  // Start the rotation
  if (tabItems.length > 0) {
    switchTab(0);
  }
});
</script>