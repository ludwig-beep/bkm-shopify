{{ 'shopdev-currency-and-language-selector.css' | asset_url | stylesheet_tag }}

<div class="shopdev" style="background-color: {{ section.settings.background_color }};">
  <div class="container mx-auto px-4 py-6">
    <div class="flex flex-col md:flex-row items-center justify-center gap-6">
      <!-- Currency & Language Selector -->
      <div class="w-full md:w-auto">
        <!-- Transcy Switcher Code - DO NOT MODIFY -->
        <div id="transcy-currency-and-language-selector">
          <div class="transcy-switcher-manual transcy-desktop hidden"></div>
          <div class="transcy-switcher-manual transcy-mobile hidden"></div>
        </div>
        <!-- End Transcy Switcher Code -->
      </div>
      
      {% if section.settings.show_description %}
        <div class="text-white text-center md:text-left">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .shopdev-currency-and-language-selector #transcy-currency-and-language-selector {
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>

{% schema %}
{
  "name": "Currency & Language Selec",
  "class": "shopdev shopdev-currency-and-language-selector",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#0066cc"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Select your preferred currency and language</p>"
    }
  ],
  "presets": [
    {
      "name": "Currency & Language",
      "settings": {
        "background_color": "#0066cc",
        "show_description": false,
        "description": "<p>Select your preferred currency and language</p>"
      }
    }
  ]
}
{% endschema %}