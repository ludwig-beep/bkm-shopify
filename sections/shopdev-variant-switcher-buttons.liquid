    }
  ],
  "presets": [
    {
      "name": "Variant Switcher Buttons",
      "settings": {
        "product": "tranquil",
        "button_1_label": "Single Bottle",
        "button_2_label": "Value Pack",
        "show_product_title": true,
        "show_prices": true,
        "show_variant_info": true,
        "title_color": "#1a1a1a",
        "button_bg_color": "#ffffff",
        "button_text_color": "#1a1a1a",
        "active_border_color": "#4f46e5",
