{% schema %}
{
  "name": "Three Column Features",
  "settings": [
    {
      "type": "select",
      "id": "spacing",
      "label": "Section Width",
      "options": [
        {
          "value": "contained",
          "label": "Contained"
        },
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "full-width-padded",
          "label": "Full Width Padded"
        }
      ],
      "default": "contained"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description goes here"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Three Column Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "News",
            "description": "For me, it's all about gaining the extra focus and",
            "link": "/news"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Sleep",
            "description": "For me, it's all about gaining the extra focus and",
            "link": "/sleep"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Woman's health",
            "description": "For me, it's all about gaining the extra focus and",
            "link": "/womans-health"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{% assign container_class = "" %}
{% case section.settings.spacing %}
  {% when "contained" %}
    {% assign container_class = "max-w-7xl mx-auto px-4" %}
  {% when "full-width" %}
    {% assign container_class = "w-full" %}
  {% when "full-width-padded" %}
    {% assign container_class = "w-full px-8" %}
{% endcase %}

<section class="py-16 {{ container_class }}">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
    {% for block in section.blocks %}
      {% if block.type == "feature" %}
        <a href="{{ block.settings.link }}" class="flex flex-col items-center text-center space-y-4 p-4 rounded-lg transition-colors hover:bg-gray-50">
          <div class="w-12 h-12 flex items-center justify-center">
            {% if block.settings.icon_image %}
              {{ block.settings.icon_image | image_url: width: 48 | image_tag: 
                class: "w-12 h-12 object-contain",
                loading: "lazy",
                alt: block.settings.title
              }}
            {% endif %}
          </div>
          <h3 class="text-lg font-semibold">{{ block.settings.title }}</h3>
          <p class="text-gray-600 max-w-xs">{{ block.settings.description }}</p>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>