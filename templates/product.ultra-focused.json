{"sections":{"main":{"type":"product","blocks":{"klaviyo_reviews_average_rating_QYLbwX":{"type":"shopify:\/\/apps\/klaviyo-reviews\/blocks\/average-rating\/db20e365-d984-4ac4-9655-e1588d951ca9","settings":{"product":"{{product}}"}},"text_qf4KFw":{"type":"text","settings":{"title":"<p>{{ product.metafields.descriptors.subtitle.value }} <\/p>","text_alignment":"left","padding_bottom":0}},"title":{"type":"title","settings":{"subheading":"none","show_rating":true,"show_rating_count":false,"padding_bottom":20}},"inventory_countdown":{"type":"inventory_countdown","disabled":true,"settings":{"max_inventory":10,"hide_inventory_count":true,"padding_bottom":20}},"text_mqhJyF":{"type":"text","settings":{"title":"<ul><li><strong>Get energized longer, without dips<\/strong><\/li><li><strong>Enhances focus and mental clarity<\/strong><\/li><li><strong>Helps maintain cognitive function<\/strong><\/li><\/ul>","text_alignment":"left","padding_bottom":0}},"text_pVNUNP":{"type":"text","disabled":true,"settings":{"title":"<p><strong>Pre-order now, orders will be shipped out by July 15th at the latest.<\/strong><\/p>","text_alignment":"left","padding_bottom":20}},"custom_code_p7TYf7":{"type":"custom_code","disabled":true,"settings":{"custom_code":"<div class=\"product-form__input product-form__input--variant\">\n  {% unless product.has_only_default_variant %}\n    <div class=\"product-form__buttons\">\n      <fieldset class=\"js product-form__input custom-variant-picker\">\n        {% for variant in product.variants %}\n          <input type=\"radio\" \n                 id=\"template--{{ section.id }}--{{ variant.id }}\" \n                 name=\"id\" \n                 value=\"{{ variant.id }}\" \n                 form=\"product-form-{{ section.id }}\" \n                 class=\"variant-input\" \n                 data-variant-image=\"{% if variant.featured_image %}{{ variant.featured_image | img_url: 'master' }}{% endif %}\" \n                 {% if variant == product.selected_or_first_available_variant %}checked{% endif %} \n                 {% if variant.available == false %}disabled{% endif %}>\n          <label for=\"template--{{ section.id }}--{{ variant.id }}\" class=\"custom-variant-button\">\n            {{ variant.title }}\n          <\/label>\n        {% endfor %}\n      <\/fieldset>\n    <\/div>\n  {% endunless %}\n<\/div>\n\n<style>\n.product-form__input.product-form__input--variant {\n  border: none !important;\n  padding: 0;\n  margin: 0;\n}\n\n.product-form__input fieldset.custom-variant-picker {\n  border: none !important;\n  padding: 0;\n  margin: 0;\n}\n\n.custom-variant-button {\n  display: inline-block;\n  padding: 12px 24px;\n  margin: 5px;\n  border: none;\n  border-radius: 6px;\n  background: #f5f5f5;\n  color: #333;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  font-weight: 500;\n}\n\n.custom-variant-button:hover {\n  background: #e8e8e8;\n}\n\ninput[type=\"radio\"]:checked + .custom-variant-button {\n  background: #333;\n  color: white;\n}\n\nfieldset.custom-variant-picker input[type=\"radio\"] {\n  display: none;\n}\n<\/style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  const variantInputs = document.querySelectorAll('.variant-input');\n  \n  variantInputs.forEach(function(input) {\n    input.addEventListener('change', function() {\n      console.log('Variant changed to:', this.value);\n      \n      \/\/ Update the main product form with the selected variant\n      const mainForm = document.querySelector('form[action*=\"\/cart\/add\"]');\n      if (mainForm) {\n        const mainVariantInput = mainForm.querySelector('input[name=\"id\"]');\n        if (mainVariantInput) {\n          mainVariantInput.value = this.value;\n        }\n      }\n      \n      \/\/ Change the product image\n      const variantImage = this.getAttribute('data-variant-image');\n      console.log('Variant image URL:', variantImage);\n      \n      if (variantImage) {\n        \/\/ Enhanced selectors for Palo Alto theme\n        const imageSelectors = [\n          '.product__media img',\n          '.product-single__photo img', \n          '.product__image img',\n          '.featured-image img',\n          '.product-media img',\n          '.product__photo img',\n          '.product-gallery img',\n          '[data-product-image]',\n          '.main-product-image img',\n          '.product__media-item img',\n          '.product-media__image img',\n          '.media img',\n          '.product__media-wrapper img',\n          'img[src*=\"MG_4178\"]', \/\/ Target the specific current image\n          'img[alt*=\"Ultra\"]' \/\/ Target images with \"Ultra\" in alt text\n        ];\n        \n        let productImage = null;\n        \n        \/\/ Try each selector until we find an image\n        for (let selector of imageSelectors) {\n          productImage = document.querySelector(selector);\n          if (productImage) {\n            console.log('Found image with selector:', selector);\n            break;\n          }\n        }\n        \n        \/\/ If still not found, try to find any image containing the current product image\n        if (!productImage) {\n          const allImages = document.querySelectorAll('img');\n          for (let img of allImages) {\n            if (img.src && img.src.includes('MG_4178')) {\n              productImage = img;\n              console.log('Found image by current src match');\n              break;\n            }\n          }\n        }\n        \n        if (productImage) {\n          console.log('Changing image from:', productImage.src, 'to:', variantImage);\n          \n          \/\/ Ensure the URL has the protocol\n          const fullImageUrl = variantImage.startsWith('\/\/') ? 'https:' + variantImage : variantImage;\n          \n          productImage.src = fullImageUrl;\n          if (productImage.srcset) {\n            productImage.srcset = fullImageUrl;\n          }\n          \n          \/\/ Also update any parent picture elements\n          const parentPicture = productImage.closest('picture');\n          if (parentPicture) {\n            const sources = parentPicture.querySelectorAll('source');\n            sources.forEach(source => {\n              source.srcset = fullImageUrl;\n            });\n          }\n          \n          console.log('Image updated successfully');\n        } else {\n          console.log('No product image element found with any selector');\n          console.log('Available images on page:');\n          document.querySelectorAll('img').forEach((img, index) => {\n            console.log(`Image ${index}:`, img.src, img.className, img.alt);\n          });\n        }\n      }\n      \n      \/\/ Trigger variant change event for other scripts\n      const event = new CustomEvent('variant:change', {\n        detail: {\n          variant: {\n            id: this.value,\n            featured_image: variantImage\n          }\n        }\n      });\n      document.dispatchEvent(event);\n    });\n  });\n});\n<\/script>","padding_bottom":20}},"custom_product_block_NrNcJy":{"type":"custom-product-block","settings":{"padding_bottom":20}},"variant_selector_enhanced_aqfiMq":{"type":"variant_selector_enhanced","settings":{"variant_title":"Select Variant","out_of_stock_indicator":"(Out of Stock)","padding_top":0,"padding_bottom":20,"margin_bottom":0}},"variant_sub_picker_87wTEV":{"type":"variant_sub_picker","disabled":true,"settings":{"padding_bottom":20}},"recharge_subscriptions_subscription_widget_v2_DBUEwp":{"type":"shopify:\/\/apps\/recharge-subscriptions\/blocks\/subscription-widget-v2\/371eed76-0b44-4869-9813-730372ea378e","settings":{}},"divider_atRVNG":{"type":"divider","settings":{"show_line":false,"padding_bottom":20}},"form":{"type":"form","settings":{"show_labels":false,"show_quantity":false,"show_payment_button":false,"enable_subscriptions_selectors":false,"padding_bottom":20}},"description":{"type":"description","disabled":true,"settings":{"padding_bottom":20}},"recha