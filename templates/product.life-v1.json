on_color":"btn--black","button_style":"btn--solid","button_size":"btn--small","video_text":"","video_link":"","bg_color_secondary":false,"gradient":"","animation":"horizontal","animation_intensity":50,"width":"wrapper--full-padded","padding_top":60,"padding_bottom":60}},"custom_tabs_section_yFt96c":{"type":"custom-tabs-section","blocks":{"tab_nUfiEP":{"type":"tab","settings":{"tab_title":"Daniel Windahl","tab_image":"shopify:\/\/shop_images\/IMG_6332.jpg","tab_name":"Daniel Windahl","tab_quote":"“For me, it's all about gaining the extra focus and rest between my practice and matches. If you have high goals, you need high quality help as BKM”","tab_role":"#1 padel, Northern Europe"}},"tab_TDUWzg":{"type":"tab","settings":{"tab_title":"Li","tab_image":"shopify:\/\/shop_images\/Li_medal_IMG_BKM.webp","tab_name":"Li Karlsén","tab_quote":"Life NAD+ isn't just another supplement, it's about supporting your body at its most fundamental level. We developed this formula to help maintain the natural NAD+ levels that begin declining after 25, and I use it daily as part of my own performance and recovery routine.","tab_role":"Nordic champion in free diving & co-founder BKM"}}},"block_order":["tab_nUfiEP","tab_TDUWzg"],"settings":{"section_title":"Proven by Performers","title_alignment":"left","section_width":"page_width","padding_top":20,"padding_bottom":20,"show_tab_buttons":false}},"section_banner_image_LxMAWQ":{"type":"section-banner-image","blocks":{"heading_7eqdwH":{"type":"heading","settings":{"text":"<h3>Longevity: Live Your Best Today and Tomorrow<\/h3>","size":180,"heading_highlight_type":"italics","highlight_color":"#d43747","highlight_text_color":"#000000"}},"text_V96wR9":{"type":"text","settings":{"text":"<p>After the age of 25, the natural production of NAD+ starts to decline, which may be associated with reduced energy and slower cell repair.<br\/><\/p>","size":100}},"text_iCcj8J":{"type":"text","settings":{"text":"<p>NR, the main ingredient in Life NAD+, is a precursor to NAD+ in the body, supporting your overall cellular health and vitality.<\/p>","size":100}}},"block_order":["heading_7eqdwH","text_V96wR9","text_iCcj8J"],"settings":{"height":"six-fifty-height","enable_mobile_height":false,"mobile_height":"four-fifty-height-mobile","image":"shopify:\/\/shop_images\/rock-bkm.jpg","overlay_opacity":10,"transition":"zoom-out","enable_zoom_animation":true,"text_width":"normal","text_position":"left","text_color":"text-light"}},"section_text_i9DFxi":{"type":"section-text","blocks":{"heading_wnCUzy":{"type":"heading","settings":{"text":"<p>Ingredients:<\/p>","size":100,"heading_highlight_type":"italics","highlight_color":"#d43747","highlight_text_color":"#000000"}},"text_QWVhmt":{"type":"text","settings":{"text":"<p>BKM supplements are formulated with a variety of ingredients, each chosen for their specific bioactive properties that address different biological needs in the human body. All BKM supplements are created in Sweden.<\/p>","size":100}}},"block_order":["heading_wnCUzy","text_QWVhmt"],"disabled":true,"settings":{"text_position":"center","bg_color_secondary":false,"text_color":"text-dark","width":"wrapper--narrow","padding_top":60,"padding_bottom":60}},"section_image_BXhgzY":{"type":"section-image","disabled":true,"settings":{"image":"shopify:\/\/shop_images\/Frame_40_5e5a8796-a84b-4e3e-9e62-e9bd2da6043b.png","height":"original-height","enable_mobile_height":false,"mobile_height":"original-height-mobile","enable_stretch":true,"image_position":"center","bg_color_secondary":false,"width":"wrapper--full-padded","padding_top":0,"padding_bottom":40}},"38ff978b-66eb-4318-9ce0-94db8ff86311":{"type":"section-columns","blocks":{"template--18952594129217__38ff978b-66eb-4318-9ce0-94db8ff86311-1683126238ada0cf52-0":{"type":"text_block","settings":{"image":"shopify:\/\/shop_images\/li-meditation.jpg","title":"1. Before sleep","text":"<p>Initially, the natural ingredients will reduce your cortisol and stress levels, making you feel more relaxed and facilitating a smoother transition into a state of calm.<\/p>","button_text":"","button_link":"","button_color":"btn--black","button_style":"btn--text","button_size":"btn--small","video_link_popup":"","video_link_color":"text-dark"}},"template--18952594129217__38ff978b-66eb-4318-9ce0-94db8ff86311-1683126238ada0cf52-1":{"type":"text_block","settings":{"title":"2. Falling asleep","text":"<p>Higher cortisol and stress levels is often the reason we “sit up and think” without being able to sleep, so by lowering these levels you will be able to fall asleep quicker and easier.<\/p>","button_text":"","button_link":"","button_color":"btn--black","button_style":"btn--text","button_size":"btn--small","video_link_popup":"","video_link_color":"text-dark"}},"template--18952594129217__38ff978b-66eb-4318-9ce0-94db8ff86311-1683126238ada0cf52-2":{"type":"text_block","settings":{"title":"3. During sleep","text":"<p>The magnesium is essential for the body to be able to fall into REM sleep, the sleep that makes you energised.<\/p>","button_text":"","button_link":"","button_color":"btn--black","button_style":"btn--text","button_size":"btn--small","video_link_popup":"","video_link_color":"text-dark"}},"text_block_xWKCCm":{"type":"text_block","settings":{"title":"4. Long Term effects","text":"<p>Ashwagandha improves blood flow to the brain, L-Theanine promotes mental relaxation, aiding in stress management without causing drowsiness. Summarized, this support brain health, cognitive abilities, and overall mental well-being.<\/p>","button_text":"","button_link":"","button_color":"btn--black","button_style":"btn--text","button_size":"btn--small","video_link_popup":"","video_link_color":"text-dark"}}},"block_order":["template--18952594129217__38ff978b-66eb-4318-9ce0-94db8ff86311-1683126238ada0cf52-0","template--18952594129217__38ff978b-66eb-4318-9ce0-94db8ff86311-1683126238ada0cf52-1","template--18952594129217__38ff978b-66eb-4318-9ce0-94db8ff86311-1683126238ada0cf52-2","text_bloc