    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Button hover background color",
      "default": "#e8e8e8"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Button Colors - Active/Selected State"
    },
    {
      "type": "color",
      "id": "button_active_background_color",
      "label": "Button active background color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_active_text_color",
      "label": "Button active text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_active_border_color",
      "label": "Button active border color",
      "default": "#333333"
